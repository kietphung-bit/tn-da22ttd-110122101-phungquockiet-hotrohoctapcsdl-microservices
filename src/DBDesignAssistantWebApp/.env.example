# DATN local demo defaults.
# Copy to .env only for local overrides. Do not commit real secrets.
# For VPS/staging, start from .env.vps.example instead.

POSTGRES_DB=tempdb
POSTGRES_USER=postgres
POSTGRES_PASSWORD=

AI_PROVIDER=MOCK
AI_RAG_TOP_K=3
AI_CHAT_RATE_LIMIT_PER_MINUTE=10
AI_CHAT_HISTORY_WINDOW_MESSAGES=8
AI_GEMINI_API_KEY=
AI_GEMINI_MODEL=gemini-2.0-flash
AI_OPENAI_API_KEY=
AI_OPENAI_MODEL=gpt-4o-mini
AI_DEEPSEEK_API_KEY=
AI_DEEPSEEK_BASE_URL=https://api.deepseek.com
AI_DEEPSEEK_MODEL=deepseek-v4-flash
AI_DEEPSEEK_TIMEOUT_SECONDS=30

AI_EMBEDDING_PROVIDER=MOCK
AI_EMBEDDING_MODEL=mock-hashing-embedding
AI_EMBEDDING_DIMENSION=384
AI_EMBEDDING_PGVECTOR_ENABLED=true
AI_VECTOR_RETRIEVAL_ENABLED=true
AI_EMBEDDING_VECTOR_INDEX_ENABLED=true
AI_EMBEDDING_GENERATE_ON_STARTUP=false

EVALUATION_ASYNC_ENABLED=true
EVALUATION_REDIS_QUEUE=evaluation:jobs

AI_WORKER_EVALUATION_QUEUE_NAME=evaluation:jobs
AI_WORKER_EVALUATION_DEAD_LETTER_QUEUE_NAME=evaluation:jobs:dead-letter
AI_WORKER_EVALUATION_MAX_RETRIES=3
AI_WORKER_REDIS_WORKER_ENABLED=true
AI_WORKER_EVALUATION_PROVIDER=MOCK
AI_WORKER_EVALUATION_PROVIDER_TIMEOUT_SECONDS=30
AI_WORKER_GEMINI_API_KEY=
AI_WORKER_GEMINI_MODEL=gemini-2.0-flash
AI_WORKER_DEEPSEEK_API_KEY=
AI_WORKER_DEEPSEEK_BASE_URL=https://api.deepseek.com
AI_WORKER_DEEPSEEK_MODEL=deepseek-v4-flash

VITE_API_BASE_URL=/api

# Demo-only default. Override locally for non-demo use.
JWT_SECRET=changeit-changeit-changeit-changeit-please
APP_SEED_ENABLED=true
APP_SEED_DEFAULT_PASSWORD=
APP_SEED_ADMIN_PASSWORD=
APP_SEED_INSTRUCTOR_PASSWORD=
APP_SEED_STUDENT_PASSWORD=
APP_SEED_RESET_EXISTING_PASSWORDS=false
